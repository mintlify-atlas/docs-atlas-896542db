  "keyFeatures": [
    "Spec-driven development workflow for AI coding assistants",
    "Slash commands (/opsx:propose, /opsx:apply, /opsx:archive) for AI chat interfaces",
    "Delta specs: ADDED/MODIFIED/REMOVED requirements for brownfield development",
    "Artifact dependency graph (proposal → specs → design → tasks)",
    "Custom workflow schemas with configurable artifact sequences",
    "Support for 20+ AI coding tools (Claude Code, Cursor, Windsurf, Copilot, etc.)",
    "CLI for project setup, validation, status inspection, and change management",
    "Parallel change management with conflict resolution on archive"
  ],
  "publicApiSurface": [
    "openspec init [path] [--tools] [--force] [--profile]",
    "openspec update [path] [--force]",
    "openspec list [--specs] [--changes] [--json]",
    "openspec show [item-name] [--type] [--json]",
    "openspec validate [item-name] [--all] [--strict] [--json]",
    "openspec archive [change-name] [-y] [--skip-specs]",
    "openspec status [--change] [--schema] [--json]",
    "openspec instructions [artifact] [--change] [--json]",
    "openspec schemas [--json]",
    "openspec schema init <name> [--artifacts] [--default]",
    "openspec schema fork <source> [name]",
    "openspec schema validate [name]",
    "openspec schema which [name] [--all]",
    "openspec config <subcommand>",
    "openspec feedback <message>",
    "openspec completion <subcommand>",
    "/opsx:propose [change-name]",
    "/opsx:explore [topic]",
    "/opsx:apply [change-name]",
    "/opsx:archive [change-name]",
    "/opsx:new [change-name] [--schema]",
    "/opsx:continue [change-name]",
    "/opsx:ff [change-name]",
    "/opsx:verify [change-name]",
    "/opsx:sync [change-name]",
    "/opsx:bulk-archive [change-names...]",
    "/opsx:onboard"
  ]
}
